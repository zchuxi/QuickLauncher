<ContentDialog
    x:Class="QuickLauncher.Views.HotkeySettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:QuickLauncher.Models"
    Title="快捷键映射"
    PrimaryButtonText="保存"
    CloseButtonText="关闭"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    x:Name="Self">

    <ContentDialog.Resources>
        <DataTemplate x:Key="HotkeyItemTemplate" x:DataType="models:HotkeyConfig">
            <Grid Padding="12,10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 快捷键徽章 -->
                <Border Grid.Column="0" Style="{StaticResource HotkeyBadgeStyle}">
                    <TextBlock Text="{x:Bind DisplayKey}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="13"
                               Foreground="White"/>
                </Border>

                <!-- 箭头 -->
                <FontIcon Grid.Column="1"
                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                          Glyph="&#xE72A;"
                          FontSize="12"
                          Opacity="0.6"/>

                <!-- 动作描述 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{x:Bind ActionDescription}"
                               Style="{StaticResource BodyTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind AppName, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>

                <!-- 删除按钮 -->
                <Button Grid.Column="3"
                        Style="{StaticResource SubtleButtonStyle}"
                        Click="DeleteHotkey_Click"
                        ToolTipService.ToolTip="删除">
                    <FontIcon FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                              Glyph="&#xE74D;" FontSize="14"/>
                </Button>
            </Grid>
        </DataTemplate>
    </ContentDialog.Resources>

    <Grid Width="520" Height="440">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 快捷键列表 -->
        <ListView Grid.Row="0"
                  ItemsSource="{x:Bind ViewModel.Hotkeys, Mode=OneWay}"
                  ItemTemplate="{StaticResource HotkeyItemTemplate}"
                  SelectionMode="None"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  CornerRadius="8"
                  BorderBrush="{ThemeResource CardBorderBrush}"
                  BorderThickness="1"/>

        <!-- 新增录入区 -->
        <StackPanel Grid.Row="1" Spacing="10" Margin="0,16,0,0">
            <!-- 添加按钮 / 录入区切换 -->
            <Grid Visibility="{x:Bind ViewModel.IsAdding, Mode=OneWay, Converter={StaticResource NegationBoolToVisibilityConverter}}">
                <Button Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.StartAddCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="添加新快捷键"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 录入表单 -->
            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.IsAdding, Mode=OneWay}">
                <Border Style="{StaticResource SettingCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="按下要绑定的按键组合" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8"/>
                        <TextBox x:Name="KeyRecorderBox"
                                 PlaceholderText="在此处按下按键..."
                                 Text="{x:Bind ViewModel.NewKeyDisplay, Mode=TwoWay}"
                                 IsReadOnly="True"
                                 KeyDown="KeyRecorderBox_KeyDown"/>
                        <TextBlock Text="选择动作" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8" Margin="0,4,0,0"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableActions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.NewAction, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="选择动作"/>
                        <TextBlock Text="选择目标应用（仅启动应用动作）" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8" Margin="0,4,0,0"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableApps, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedApp, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="选择应用"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.ConfirmAddCommand}"
                                    Content="确认"/>
                            <Button Style="{StaticResource DefaultButtonStyle}"
                                    Command="{x:Bind ViewModel.CancelAddCommand}"
                                    Content="取消"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</ContentDialog>
